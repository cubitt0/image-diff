{
    "name": "app/image-diff",
    "description": "Image comparison tool built with Symfony",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "symfony/framework-bundle": "^7.1",
        "symfony/twig-bundle": "^7.1",
        "symfony/yaml": "^7.1",
        "symfony/runtime": "^7.1",
        "symfony/string": "^7.1"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "allow-plugins": {
            "symfony/runtime": true
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "7.1.*"
        }
    }
}
